{
  "name": "agent-workflows",
  "version": "0.0.1",
  "description": "Run JS workflow files that orchestrate Codex and Claude Code agents (agent()/parallel()/pipeline()/phase()).",
  "type": "module",
  "bin": {
    "agent-workflows": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/dsl/ambient.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "node --test --import tsx ./test/*.test.ts",
    "start": "node dist/cli.js",
    "viewer:dev": "pnpm -C viewer dev",
    "viewer:build": "pnpm -C viewer build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.163",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
